@LIT_SITE_CFG_IN_HEADER@

config.llvm_tools_dir = r"@GEMMINI_LLVM_TOOLS_DIR@"
config.onnx_mlir_tools_dir = r"@ONNX_MLIR_TOOLS_DIR@"
config.onnx_mlir_obj_root = r"@ONNX_MLIR_BIN_ROOT@"
config.gemmini_test_tools_dir = r"@GEMMINI_TEST_TOOLS_DIR@"
config.gemmini_repo_root = r"@GEMMINI_REPO_ROOT@"
config.gemmini_resnet18_model = r"@GEMMINI_RESNET18_MODEL@"
config.gemmini_mobilenetv2_model = r"@GEMMINI_MOBILENETV2_MODEL@"
config.gemmini_bert_tiny_model = r"@GEMMINI_BERT_TINY_MODEL@"
config.gemmini_examples_dir = r"@GEMMINI_EXAMPLES_TESTS_DIR@"
config.gemmini_riscv_install = r"@GEMMINI_RISCV_INSTALL@"

try:
    config.llvm_tools_dir = config.llvm_tools_dir % lit_config.params
    config.onnx_mlir_tools_dir = config.onnx_mlir_tools_dir % lit_config.params
except KeyError:
    e = sys.exc_info()[1]
    key, = e.args
    lit_config.fatal("unable to find %r parameter, use '--param=%s=VALUE'" % (key, key))

import lit.llvm
lit.llvm.initialize(lit_config, config)

lit_config.load_config(config, r"@CMAKE_CURRENT_SOURCE_DIR@/lit.cfg.py")
