//===------------------------ GemminiTargetInfo.hpp ----------------------===//
//
// Generated compiler-side target-parameter helpers for the Gemmini backend.
//
// This file is configured by Support/CMakeLists.txt from:
//   Runtime/gemmini-hardware-abi/include/gemmini_params.h
//
// Do not edit the generated copy in the build tree. Update gemmini_params.h or
// this template instead.
//
//===----------------------------------------------------------------------===//

#ifndef ONNX_MLIR_GEMMINI_TARGET_INFO_H
#define ONNX_MLIR_GEMMINI_TARGET_INFO_H

#include <cstdint>

namespace onnx_mlir {
namespace gemmini {

/** Compiler-visible Gemmini hardware parameters.
 *
 * CMake configures this template from the bundled hardware ABI header so
 * compiler passes and runtime code share one source of truth for DIM,
 * scratchpad size, accumulator size, and element widths.
 */
struct GemminiTargetInfo {
  // Matrix array dimension from Gemmini's DIM parameter.
  static constexpr int64_t dim = @GEMMINI_TARGET_DIM@;
  // Number of scratchpad memory banks configured in hardware.
  static constexpr int64_t bankNum = @GEMMINI_TARGET_BANK_NUM@;
  // Number of rows available in each scratchpad bank.
  static constexpr int64_t bankRows = @GEMMINI_TARGET_BANK_ROWS@;
  // Number of accumulator rows available to Gemmini operations.
  static constexpr int64_t accRows = @GEMMINI_TARGET_ACC_ROWS@;
  // Bit width of one input/activation element.
  static constexpr int64_t elemBits = @GEMMINI_TARGET_ELEM_BITS@;
  // Bit width of one accumulator element.
  static constexpr int64_t accBits = @GEMMINI_TARGET_ACC_BITS@;

  // Total addressable scratchpad rows across all banks.
  static constexpr int64_t scratchpadRows() { return bankNum * bankRows; }
  // Number of DIM x DIM matrices that fit in the scratchpad.
  static constexpr int64_t scratchpadMatrices() {
    return scratchpadRows() / dim;
  }
  // Number of DIM x DIM matrices that fit in the accumulator.
  static constexpr int64_t accumulatorMatrices() { return accRows / dim; }

  // Integer ceil(value / divisor), used to count partial edge tiles.
  static constexpr int64_t ceilDiv(int64_t value, int64_t divisor) {
    return (value + divisor - 1) / divisor;
  }

  // Tile counts for an MxK by KxN matmul under the configured DIM.
  struct MatmulTileCounts {
    // Number of tiles along the output M dimension.
    int64_t mTiles;
    // Number of tiles along the output N dimension.
    int64_t nTiles;
    // Number of tiles along the reduction K dimension.
    int64_t kTiles;
  };

  /** Return how many DIM-sized tiles cover an MxK by KxN matmul. */
  static constexpr MatmulTileCounts getMatmulTileCounts(
      int64_t m, int64_t n, int64_t k) {
    return {ceilDiv(m, dim), ceilDiv(n, dim), ceilDiv(k, dim)};
  }
};

} // namespace gemmini
} // namespace onnx_mlir

#endif
